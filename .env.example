# ── Provider keys ─────────────────────────────────────────────────────────────

# Neysa — default for chat/generation (provided at AIBoomi Startup Weekend BLR)
# Endpoints: deepseek-v4-flash | gemma-4-26b-a4b-it | qwen3.6-27b
NEYSA_API_KEY=your_neysa_psai_key_here
NEYSA_BASE_URL=https://neysa-deepseek-v4flash.pipeshift.com/v1

# FastRouter — alternative chat provider (set CHAT_PROVIDER=fastrouter to use)
# Redeem $50: fastrouter.ai → Credits → promo code BUILDWITHFASTROUTERBLR26
FASTROUTER_API_KEY=your_fastrouter_api_key_here
FASTROUTER_BASE_URL=https://api.fastrouter.ai/v1

# OpenAI — used for embeddings / RAG index (optional; app boots without it)
OPENAI_API_KEY=your_openai_api_key_here

# ── Chat provider selection ────────────────────────────────────────────────────
# Which provider handles chat() / chat_json(). Default: neysa
# CHAT_PROVIDER=fastrouter

# ── Model selection ────────────────────────────────────────────────────────────
CHEAP_MODEL=deepseek-v4-flash
STRONG_MODEL=deepseek-v4-flash

# Embedding model (OpenAI only)
EMBED_MODEL=text-embedding-3-small

# ── Course selection ───────────────────────────────────────────────────────────
ACTIVE_COURSE=sql
