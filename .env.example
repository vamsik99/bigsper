# ── Provider keys ─────────────────────────────────────────────────────────────

# FastRouter — default for chat / generation
FASTROUTER_API_KEY=your_fastrouter_api_key_here
FASTROUTER_BASE_URL=https://api.fastrouter.ai/v1

# OpenAI — direct fallback for chat + embeddings fallback
OPENAI_API_KEY=your_openai_api_key_here

# Neysa — default for embeddings
NEYSA_API_KEY=your_neysa_api_key_here
NEYSA_BASE_URL=https://api.neysa.ai/v1

# ── Model selection ────────────────────────────────────────────────────────────

# Used by llm.chat(tier="cheap") and llm.chat(tier="strong")
CHEAP_MODEL=gpt-4o-mini
STRONG_MODEL=gpt-4o

# Embedding model (used by both Neysa and OpenAI fallback paths)
EMBED_MODEL=text-embedding-3-small

# ── Course selection ───────────────────────────────────────────────────────────

# Which course to activate at startup. Must match a directory under courses/.
ACTIVE_COURSE=sql
